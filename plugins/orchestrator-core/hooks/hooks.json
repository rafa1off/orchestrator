{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "rm",
            "args": [
              "-f",
              "${CLAUDE_PROJECT_DIR}/.claude/pipeline/verify-findings.json",
              "${CLAUDE_PROJECT_DIR}/.claude/pipeline/pre-compact-snapshot.md"
            ]
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "verify",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-c",
              "FILE=\"${CLAUDE_PROJECT_DIR}/.claude/pipeline/verify-findings.json\"; { [ -f \"$FILE\" ] && { ! command -v jq >/dev/null 2>&1 || jq -e . \"$FILE\" >/dev/null 2>&1; }; } || { echo '[orchestrator] BLOCKED: verify exited without valid findings JSON. Re-invoke write_findings before stopping.' >&2; exit 2; }"
            ]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__.*__write_findings",
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-findings.sh"]
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-c",
              "P=\"${CLAUDE_PROJECT_DIR}/.claude/pipeline\"; { printf '# Pipeline Snapshot — %s\\n' \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"; for f in verify-findings.json; do [ -f \"$P/$f\" ] && { printf '## %s\\n' \"$f\"; cat \"$P/$f\"; echo; }; done; [ -f \"$P/progress.md\" ] && { printf '## progress.md\\n'; cat \"$P/progress.md\"; echo; }; } > \"$P/pre-compact-snapshot.md\" 2>/dev/null || true"
            ]
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash",
            "args": [
              "-c",
              "L=\"${CLAUDE_PROJECT_DIR}/.claude/pipeline/session-log.txt\"; mkdir -p \"$(dirname \"$L\")\"; printf '%s session-end\\n' \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" >> \"$L\"; rm -f \"${CLAUDE_PROJECT_DIR}/.claude/pipeline/verify-findings.json\" \"${CLAUDE_PROJECT_DIR}/.claude/pipeline/pre-compact-snapshot.md\""
            ]
          }
        ]
      }
    ]
  }
}
